# Python 项目标准忽略规则
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# pytest 缓存目录
.pytest_cache/

# 保留 data 目录结构但忽略其中的所有文件
data/*
!data/.gitkeep

# 保留 logs 目录结构但忽略其中的所有文件
logs/*
!logs/.gitkeep

# 保留 data 目录结构但忽略其中的原始数据文件
data/raw_data/
data/*.txt
data/*.parquet

# 忽略临时文件
*.swp
*.swo
*~
*.tmp

# 忽略 IDE 相关文件
.mobile-coder/
.zhanlu/
.idea/
.vscode/
.codebuddy/
.playwright-mcp/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 忽略操作系统文件
.DS_Store
Thumbs.db

# 忽略配置文件中的敏感信息
*.env
.env
config/credentials.json

# 忽略数据文件
*.csv
*.xls
*.xlsx
*.parquet

# 忽略测试数据目录
test_data/

# 忽略测试用例
tests/